[Unit]
Description=llama.cpp server for Qwen3.6-35B-A3B
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=kzkchd
WorkingDirectory=/home/kzkchd/llm
Environment=CUDA_VISIBLE_DEVICES=0
ExecStart=/home/kzkchd/llm/scripts/start-qwen36.sh
ExecStop=/home/kzkchd/llm/scripts/stop-qwen36.sh
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
