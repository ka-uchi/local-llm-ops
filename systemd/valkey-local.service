[Unit]
Description=Temporary local Valkey for Echo-Chamber LLM orchestration
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=kzkchd
WorkingDirectory=/home/kzkchd/llm
ExecStart=/home/kzkchd/llm/scripts/start-valkey.sh
ExecStop=/home/kzkchd/llm/scripts/stop-valkey.sh
TimeoutStartSec=60
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
