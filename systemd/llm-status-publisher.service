[Unit]
Description=Publish local LLM runtime status to Valkey
After=network-online.target
After=snap.valkey.server.service
Wants=network-online.target
Wants=snap.valkey.server.service

[Service]
Type=oneshot
User=REPLACE_WITH_LOCAL_USER
WorkingDirectory=REPLACE_WITH_REPO_ROOT
ExecStart=REPLACE_WITH_REPO_ROOT/scripts/publish-status-valkey.sh

[Install]
WantedBy=multi-user.target
