[Unit]
Description=llama.cpp server for Gemma 4 31B IT
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=kzkchd
WorkingDirectory=/home/kzkchd/llm
Environment=CUDA_VISIBLE_DEVICES=1
ExecStart=/home/kzkchd/llm/scripts/start-gemma4-31b.sh
ExecStop=/home/kzkchd/llm/scripts/stop-gemma4-31b.sh
TimeoutStartSec=120
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
