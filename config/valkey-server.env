# Runtime settings for a temporary local Valkey instance on the inference host.

REPO_ROOT="${REPO_ROOT:-${HOME}/llm}"

VALKEY_SERVER_BIN=
VALKEY_SERVER_HOST=127.0.0.1
VALKEY_SERVER_PORT=6379
VALKEY_SERVER_LOG_LEVEL=notice
VALKEY_SERVER_DIR="${REPO_ROOT}/var/valkey"
VALKEY_SERVER_DB_DIR="${REPO_ROOT}/var/valkey/data"
VALKEY_SERVER_PID_FILE="${REPO_ROOT}/var/valkey/valkey.pid"
VALKEY_SERVER_LOG_FILE="${REPO_ROOT}/logs/valkey.log"
VALKEY_SERVER_PASSWORD=
